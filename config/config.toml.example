# Example /etc/audiorec/config.toml.
#
# Normally you DON'T need to edit this by hand -- the web setup wizard at
# http://audiorec.local/setup writes this file for you. It's here so you
# know what shape the file takes, and for rare "I lost WiFi, let me fix
# this via SSH" moments.
#
# After hand-editing: sudo systemctl restart audiorec-recorder audiorec-uploader audiorec-webapp

[meta]
# Flipped to true by the web wizard when the user hits "Finish".
setup_complete = false

[paths]
data_dir = "/var/lib/audiorec"
recordings_subdir = "recordings"

[audio]
# ALSA device id, e.g. "hw:1,0". Find yours with `arecord -l`.
device = ""
sample_rate = 16000
channels = 1
format = "S16_LE"

[gpio]
# BCM pin numbers. Wire the button between button_pin and GND.
button_pin = 17
led_pin = 18
debounce_s = 0.05
long_press_s = 3.0

[upload]
poll_interval_s = 5
local_retention_days = 7
opus_bitrate = "24k"
multipart_part_size_mb = 5
max_retries = 10

[cloud]
# S3-compatible storage. Pick whichever you like; all use the same 6 fields.
#
#  Provider          provider    region          endpoint_url
#  Backblaze B2      "b2"        us-west-004     https://s3.us-west-004.backblazeb2.com
#  Cloudflare R2     "r2"        auto            https://<account-id>.r2.cloudflarestorage.com
#  Wasabi            "wasabi"    us-east-1       https://s3.us-east-1.wasabisys.com
#  DigitalOcean      "do"        nyc3            https://nyc3.digitaloceanspaces.com
provider = ""
access_key = ""
secret_key = ""
endpoint_url = ""
region = ""
bucket = ""
key_prefix = "recordings/"

[web]
host = "0.0.0.0"
port = 80
username = ""
# bcrypt($password) - the wizard generates this.
password_hash = ""
# Random 64-hex-char string; install.sh generates this on first run.
session_secret = ""
session_lifetime_s = 2592000
hostname = "audiorec.local"
